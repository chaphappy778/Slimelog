# apps/web/.env.example
#
# Copy to .env.local for local dev, or set these in the Vercel project's
# Environment Variables. Never commit real values — .env / .env.local are
# gitignored. NEXT_PUBLIC_* vars are exposed to the browser bundle; keep
# secrets (no NEXT_PUBLIC_ prefix) server-only.

# ─── Supabase ────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. NEVER prefix with NEXT_PUBLIC_ — that would leak full DB
# access to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# ─── Site ────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://slimelog.com
NEXT_PUBLIC_ADMIN_EMAIL=

# ─── Stripe ──────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PRO_MONTHLY_PRICE_ID=
NEXT_PUBLIC_STRIPE_PRO_YEARLY_PRICE_ID=
NEXT_PUBLIC_STRIPE_BRAND_PRO_PRICE_ID=
STRIPE_PRO_MONTHLY_INTRO_COUPON=
STRIPE_PRO_YEARLY_INTRO_COUPON=

# ─── Email (Brevo + Resend) ──────────────────────────────────────────
BREVO_API_KEY=
BREVO_WAITLIST_LIST_ID=
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# ─── Cron ────────────────────────────────────────────────────────────
# Vercel Cron sends `Authorization: Bearer <CRON_SECRET>` automatically.
CRON_SECRET=

# ─── Sentry (error tracking) ─────────────────────────────────────────
# Public DSN — safe to expose to the browser. From Sentry: Settings →
# Projects → <project> → Client Keys (DSN).
NEXT_PUBLIC_SENTRY_DSN=
# Org + project slugs — used at build time for source-map upload.
SENTRY_ORG=
SENTRY_PROJECT=
# Build-time only. Grants source-map upload. From Sentry: Settings →
# Auth Tokens. Keep it out of the browser (no NEXT_PUBLIC_ prefix).
SENTRY_AUTH_TOKEN=

# ─── PostHog (product analytics) ─────────────────────────────────────
# Project API key (public — designed to ship in the client bundle).
NEXT_PUBLIC_POSTHOG_KEY=
# Ingestion host. US cloud default below; use https://eu.i.posthog.com
# for the EU region.
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ─── Optional ────────────────────────────────────────────────────────
# Vercel exposes VERCEL_ENV to server code automatically, but not to the
# browser bundle. Set this if you want client-side Sentry events tagged
# with the correct environment (production / preview) instead of
# defaulting to "development". Mirror VERCEL_ENV's value per Vercel env.
NEXT_PUBLIC_VERCEL_ENV=
